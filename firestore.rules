rules_version = '2';

// Security rules for Levellio community projects. Deploy with:
//   firebase deploy --only firestore:rules
// (or paste into Firebase console → Firestore → Rules).
//
// Model: featured projects are world-readable; project metadata is readable by
// any signed-in user (so invite-code joins work); members/feed/cycle counters
// are readable by members (and by anyone for featured projects). A user can only
// write their own member doc and their own contributions.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // A user's own profile + their follow graph (network).
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      // Who this user follows. Readable by any signed-in user (so feeds/profiles
      // can resolve a network); writable only by the owner.
      match /following/{targetUid} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == uid;
      }

      // Inbox: the owner reads and manages (mark read / delete); any signed-in
      // actor may create a notification addressed to this user (recipientUid==uid).
      match /notifications/{notifId} {
        allow read, update, delete: if signedIn() && request.auth.uid == uid;
        allow create: if signedIn() && request.resource.data.recipientUid == uid;
      }
    }

    // Public profile snapshots — a small, public-safe projection any signed-in
    // user can read (so people can learn from each other); owner-writable only.
    match /profiles/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    // Ephemeral stories (24h). Readable by any signed-in user; an author writes
    // and deletes only their own.
    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    // Direct messages — 1:1 threads. Only participants can read/write the thread;
    // messages are readable by participants and created only by their sender.
    match /threads/{threadId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if signedIn() && request.resource.data.senderUid == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow delete: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
      }
    }

    // Community newsfeed posts (manual shares + contribution posts).
    match /posts/{postId} {
      // Visible to any signed-in member of the community.
      allow read: if signedIn();
      // Authors create their own posts.
      allow create: if signedIn() && request.resource.data.authorUid == request.auth.uid;
      // The author may edit/delete their post; anyone signed-in may toggle ONLY
      // their own reaction (reactions is a { uid: emoji } map) or bump commentCount.
      allow update: if signedIn() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'commentCount'])
      );
      allow delete: if signedIn() && resource.data.authorUid == request.auth.uid;

      // The comment thread: any signed-in user may add their own comment.
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      }
    }

    match /projects/{projectId} {
      function isMember() {
        return signedIn() &&
          exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
      }
      function isOwner() {
        return signedIn() && resource.data.ownerUid == request.auth.uid;
      }
      function isFeatured() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data.featured == true;
      }

      // Featured projects are public; other project docs are visible to any
      // signed-in user so they can resolve an invite code and join.
      allow read: if resource.data.featured == true || signedIn();
      // Any signed-in user can create a project they own.
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Owners can edit; members may only bump the denormalized memberCount.
      allow update: if isOwner() ||
        (signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']));
      allow delete: if isOwner();

      // Each member manages only their own membership doc.
      match /members/{uid} {
        allow read: if signedIn() && (isMember() || isFeatured() || resource.data.uid == request.auth.uid);
        allow create, update, delete: if signedIn() && request.auth.uid == uid;
      }

      // The activity feed: a member may only create their own contributions, and
      // may delete their own (for account deletion). No edits.
      match /contributions/{contribId} {
        allow read: if signedIn() && (isMember() || isFeatured());
        allow create: if isMember() && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if signedIn() && resource.data.uid == request.auth.uid;
      }

      // Per-cycle counter docs: writable by members (increment-only in practice).
      match /cycles/{cycleKey} {
        allow read: if signedIn() && (isMember() || isFeatured());
        allow write: if isMember();
      }
    }
  }
}
