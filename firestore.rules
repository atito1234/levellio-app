rules_version = '2';

// Security rules for Levellio community + moderation. Deploy with:
//   firebase deploy --only firestore:rules
// (or paste into Firebase console → Firestore → Rules → Publish).
//
// Model: featured projects are world-readable; project metadata is readable by any
// signed-in user (so invite-code joins work); posts enforce their audience
// (public/friends/private) server-side. Moderation backbone: an `admins/{uid}` doc
// (created in the console) grants global remove + ban powers; a `bans/{uid}` doc
// strips all write access (the "eject the offending user" lever); reports are
// write-by-anyone, read-by-admins.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    // App owner / approved moderators (set manually in the console; no client write).
    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    // A banned user loses all create/write access — required for 24h action.
    function banned() {
      return signedIn() && exists(/databases/$(database)/documents/bans/$(request.auth.uid));
    }
    function canCreate() {
      return signedIn() && !banned();
    }

    // --- Moderation backbone -------------------------------------------------
    // Admins configured in the console only.
    match /admins/{adminUid} {
      allow read: if signedIn();
      allow write: if false;
    }
    // Bans written only by admins; readable so the client can reflect state.
    match /bans/{bannedUid} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    // Reports: any non-banned user files one; only admins read / triage / resolve.
    match /reports/{reportId} {
      allow create: if canCreate() && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
    // Founding invite codes (invite-only beta): the owner creates code docs in the
    // console; a signed-in user may check one exists to unlock the community. Never
    // client-writable and never listable (so codes can't be enumerated).
    match /foundingCodes/{code} {
      allow get: if signedIn();
      allow list, write: if false;
    }
    // Project applications (delegated moderation): applicant creates + reads their
    // own; admins review / approve / reject.
    match /projectApplications/{appId} {
      allow create: if canCreate() && request.resource.data.applicantUid == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.applicantUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- A user's own profile + follow graph + inbox + blocks ----------------
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      // Who this user follows. Readable by any signed-in user; owner-writable.
      match /following/{targetUid} {
        allow read: if signedIn();
        allow write: if canCreate() && request.auth.uid == uid;
      }

      // Inbox: owner reads/manages; any non-banned actor may create a notification
      // addressed to this user (recipientUid == uid).
      match /notifications/{notifId} {
        allow read, update, delete: if signedIn() && request.auth.uid == uid;
        allow create: if canCreate() && request.resource.data.recipientUid == uid;
      }

      // Server-stored personal blocks (the client hides blocked users with these).
      match /blocks/{targetUid} {
        allow read, write, delete: if signedIn() && request.auth.uid == uid;
      }
    }

    // Public profile snapshots — any signed-in user can read; owner writes; owner
    // or an admin can delete (moderation / account deletion).
    match /profiles/{uid} {
      allow read: if signedIn();
      allow write: if canCreate() && request.auth.uid == uid;
      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // Ephemeral stories (24h). Readable by any signed-in user; author creates;
    // author or admin deletes.
    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if canCreate() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
    }

    // Direct messages — 1:1 threads. Only participants read/write the thread;
    // messages readable by participants, created by their sender; deletable by the
    // sender, a participant, or an admin.
    match /threads/{threadId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if canCreate() && request.auth.uid in request.resource.data.participants;
      allow delete: if signedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if canCreate() && request.resource.data.senderUid == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow delete: if isAdmin() || (signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants);
      }
    }

    // Community newsfeed posts (manual shares + contribution posts).
    match /posts/{postId} {
      // Audience-scoped visibility, enforced server-side (client filters too).
      function canRead(p) {
        return signedIn() && (
          !('audience' in p) ||
          p.audience == 'public' ||
          p.authorUid == request.auth.uid ||
          (p.audience == 'friends' &&
            exists(/databases/$(database)/documents/users/$(request.auth.uid)/following/$(p.authorUid)))
        );
      }
      allow read: if canRead(resource.data);
      allow create: if canCreate() && request.resource.data.authorUid == request.auth.uid;
      // Author edits own post; anyone signed-in may toggle ONLY their reaction or
      // bump commentCount.
      allow update: if signedIn() && (
        resource.data.authorUid == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'commentCount'])
      );
      // Author or an admin (moderation) may delete.
      allow delete: if isAdmin() || (signedIn() && resource.data.authorUid == request.auth.uid);

      // Comments inherit the post's audience. Commenter manages their own; the post
      // author or an admin may moderate (delete) any comment.
      match /comments/{commentId} {
        function parentPost() {
          return get(/databases/$(database)/documents/posts/$(postId)).data;
        }
        allow read: if canReadComment(postId);
        allow create: if canCreate() && request.resource.data.uid == request.auth.uid && canReadComment(postId);
        allow update: if signedIn() && resource.data.uid == request.auth.uid;
        allow delete: if isAdmin() || (signedIn() && (
          resource.data.uid == request.auth.uid ||
          parentPost().authorUid == request.auth.uid
        ));
      }
    }

    // Whether the signed-in viewer can read a given post's thread (mirrors the post
    // audience gate; used by the comments subcollection rules above).
    function canReadComment(postId) {
      let p = get(/databases/$(database)/documents/posts/$(postId)).data;
      return signedIn() && (
        !('audience' in p) ||
        p.audience == 'public' ||
        p.authorUid == request.auth.uid ||
        (p.audience == 'friends' &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/following/$(p.authorUid)))
      );
    }

    match /projects/{projectId} {
      function isMember() {
        return signedIn() &&
          exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
      }
      function isOwner() {
        return signedIn() && resource.data.ownerUid == request.auth.uid;
      }
      function projectOwnerUid() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid;
      }
      function isFeatured() {
        return get(/databases/$(database)/documents/projects/$(projectId)).data.featured == true;
      }

      allow read: if resource.data.featured == true || signedIn();
      allow create: if canCreate() && request.resource.data.ownerUid == request.auth.uid;
      // Owners or admins edit; members may only bump the denormalized memberCount.
      allow update: if isOwner() || isAdmin() ||
        (signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']));
      allow delete: if isOwner() || isAdmin();

      // Each member manages their own membership; the project owner or an admin may
      // remove a member (per-project moderation).
      match /members/{uid} {
        allow read: if signedIn() && (isMember() || isFeatured() || resource.data.uid == request.auth.uid);
        allow create, update: if canCreate() && request.auth.uid == uid;
        allow delete: if isAdmin() || (signedIn() && (request.auth.uid == uid || projectOwnerUid() == request.auth.uid));
      }

      // Activity feed: a member creates only their own contributions; the
      // contributor, the project owner, or an admin may delete. No edits.
      match /contributions/{contribId} {
        allow read: if signedIn() && (isMember() || isFeatured());
        allow create: if canCreate() && isMember() && request.resource.data.uid == request.auth.uid;
        allow update: if false;
        allow delete: if isAdmin() || (signedIn() && (resource.data.uid == request.auth.uid || projectOwnerUid() == request.auth.uid));
      }

      // Per-cycle counter docs: writable by members (increment-only in practice).
      match /cycles/{cycleKey} {
        allow read: if signedIn() && (isMember() || isFeatured());
        allow write: if canCreate() && isMember();
      }
    }
  }
}
