rules_version = '2';

// Security rules for Levellio community projects. Deploy with:
//   firebase deploy --only firestore:rules
//
// Model: featured projects are world-readable; private projects are readable by
// members. Members manage only their own member doc. Contributions and cycle
// counters can only be written by a signed-in member writing their own uid.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // A user's own profile.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /projects/{projectId} {
      function isMember() {
        return signedIn() &&
          exists(/databases/$(database)/documents/projects/$(projectId)/members/$(request.auth.uid));
      }
      function isOwner() {
        return signedIn() && resource.data.ownerUid == request.auth.uid;
      }

      // Featured projects are discoverable by everyone; private ones by members.
      allow read: if resource.data.featured == true || isMember();
      // Any signed-in user can create a project they own.
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      // Owners can edit; members may only bump the denormalized memberCount.
      allow update: if isOwner() ||
        (signedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']));
      allow delete: if isOwner();

      // Each member manages only their own membership doc.
      match /members/{uid} {
        allow read: if isMember() || resource.data.uid == request.auth.uid;
        allow create, update, delete: if signedIn() && request.auth.uid == uid;
      }

      // The activity feed: a member may only create their own contributions.
      match /contributions/{contribId} {
        allow read: if isMember() || get(/databases/$(database)/documents/projects/$(projectId)).data.featured == true;
        allow create: if isMember() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }

      // Per-cycle counter docs: writable by members (increment-only in practice).
      match /cycles/{cycleKey} {
        allow read: if isMember() || get(/databases/$(database)/documents/projects/$(projectId)).data.featured == true;
        allow write: if isMember();
      }
    }
  }
}
