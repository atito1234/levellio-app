{
  "expo": {
    "name": "Levellio",
    "slug": "levellio",
    "scheme": "levellio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C4CF1"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Levellio can attach where and how fast an activity happened (e.g. a run) to your logs, only when you turn this on — to power your personal analytics."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Levellio lets you attach a photo or video to a battle journal entry — only when you choose to add one."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.levellio.placeholder"
    },
    "android": {
      "package": "app.levellio.placeholder",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/adaptive-icon-background.png",
        "backgroundColor": "#6C4CF1"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    }
  }
}
